鬠ｿ# Configuraﾃδｧﾃδ｣o do Banco de Dados
# IMPORTANTE: Copie este arquivo para .env e preencha com suas credenciais reais
DB_HOST=localhost
DB_PORT=3306
DB_USER=cheguei_user
DB_PASSWORD=cheguei_pass
DB_NAME=cheguei_mae

# Configuraﾃδｧﾃδ｣o do Servidor
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# JWT Secret (altere em produﾃδｧﾃδ｣o para uma string aleatﾃδｳria e segura)
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# CORS Origins (separados por vﾃδｭrgula)
# Para desenvolvimento, aceita qualquer IP da rede local 192.168.x.x
# Adicione os IPs da sua rede local aqui
CORS_ORIGIN=http://localhost:8081,http://192.168.15.3:8081,http://192.168.15.7:8081